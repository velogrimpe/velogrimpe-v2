      <trkpt lat="45.897450" lon="6.709060"><ele>784</ele></trkpt>
      <trkpt lat="45.890000" lon="6.700000"><ele>800</ele></trkpt>
      <trkpt lat="45.880000" lon="6.690000"><ele>820</ele></trkpt>
    </trkseg>
