RewriteEngine On
# Redirection canonique : vélogrimpe.fr (IDN -> punycode) vers velogrimpe.fr
# Couvre le domaine accentué et son www. Conserve le chemin et la query string.
RewriteCond %{HTTP_HOST} ^(www\.)?xn--vlogrimpe-b4a\.fr$ [NC]
RewriteRule ^ https://velogrimpe.fr%{REQUEST_URI} [L,R=301]
# Force HTTPS (désactivé en dev et prod car hostinger le fait)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# Vielles URLs
RewriteRule ^ajout/admin/(.*)$ /admin/$1 [R=301,L]
RewriteRule ^admin/ajout_donnees_admin.php$ /admin/ [R=301,L]
# Feeds
RewriteRule ^feed/actualites\.xml$ /feed/actualites.php [L]
RewriteRule ^feed/nouveautes\.xml$ /feed/nouveautes.php [L]
# URLs conventionnelles -> flux Actualités (alias servis directement, sans redirection)
RewriteRule ^feed\.xml$ /feed/actualites.php [L]
RewriteRule ^(rss|feed)/?$ /feed/actualites.php [L]
RewriteRule ^actualites/([a-zA-Z0-9_-]+)$ /actualites/newsletter.php?slug=$1 [L,QSA]
RewriteRule ^p/([a-z0-9/-]+)/?$ /p/dispatch.php?slug=$1 [L,QSA]
# Sert les exports open data via download.php pour tracer chaque téléchargement.
# Réécriture INTERNE : l'URL publique reste .geojson (canonique). download.php
# lit le fichier sur disque (readfile), donc aucune boucle de réécriture.
RewriteRule ^open-data/(falaises|falaises-details|itineraires-velo|gares|complet)\.geojson$ /open-data/download.php?f=$1 [L,QSA]

ErrorDocument 404 /404.php

<FilesMatch ".*\.gpx$">
  Header set Content-Disposition attachment
  #Header set Content-Type application/gpx+xml
  ForceType application/gpx+xml
  Header set Cache-Control "max-age=31536000, public, must-revalidate"
</FilesMatch>

<FilesMatch ".*\.geojson$">
  # Force le bon Content-Type pour que la règle DEFLATE matche (sinon Apache
  # tombe sur text/plain ou octet-stream selon mime.types).
  ForceType application/geo+json
  Header set Cache-Control "max-age=31536000, public, must-revalidate"
</FilesMatch>

<FilesMatch ".*\.(webp|png|jpg|jpeg)">
  Header set Cache-Control "max-age=31536000, public, must-revalidate"
</FilesMatch>

# Disable caching for JS files — sauf les bundles de build versionnés
# (cf. plus bas). Le négative-lookahead exclut map-{x.y.z}.js et map-maplibre-{x.y.z}.js
# pour qu'ils puissent être cachés long-terme.
<FilesMatch "^(?!map(?:-maplibre)?-\d[\d.A-Za-z-]*\.js$).+\.js$">
    FileETag None
    Header unset ETag
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# Bundles de build versionnés (`map-1.9.4.js`, `map-maplibre-5.24.0.js`, etc.).
# Le filename change à chaque upgrade de lib → cache 1 an + immutable. PHP
# résout le filename courant via `dist/map-bundles.json` (cf. lib/map-bundle.php).
<FilesMatch "^map(?:-maplibre)?-\d[\d.A-Za-z-]*\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Compression gzip pour les assets bâtis (JS/CSS/JSON/SVG).
# Gain ~70% sur les bundles minifiés. No-op si mod_deflate n'est pas chargé.
# Note : Apache sert souvent le JS avec le MIME legacy `application/x-javascript`,
# on inclut donc les deux variantes.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript application/json
  AddOutputFilterByType DEFLATE application/geo+json
  AddOutputFilterByType DEFLATE text/css text/javascript text/plain text/xml text/html
  AddOutputFilterByType DEFLATE image/svg+xml application/xml

</IfModule>

# Workaround pour le bug Apache + mod_deflate : mod_deflate ajoute "-gzip" à
# l'ETag dans la réponse mais ne strip pas le suffixe du If-None-Match entrant,
# donc le navigateur reçoit toujours 200 même quand rien n'a changé. On strip
# le suffixe côté requête pour réaligner. (DeflateAlterETag NoChange serait plus
# propre mais n'est pas autorisé dans ce .htaccess sur cette config Apache.)
<IfModule mod_headers.c>
  RequestHeader edit "If-None-Match" '^"(.*)-gzip"$' '"$1"'
</IfModule>

DirectoryIndex index.php
<Limit GET POST>
  Allow from all
</Limit>
# DO NOT REMOVE THIS LINE AND THE LINES BELOW IPALLOWID:bdy3fJPHzy
allow from 45.80.9.168
