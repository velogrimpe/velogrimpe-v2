#RewriteCond %{HTTPS} off
#RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
RewriteEngine On
RewriteRule ^ajout/admin/(.*)$ /admin/$1 [R=301,L]
RewriteRule ^admin/ajout_donnees_admin.php$ /admin/ [R=301,L]
RewriteRule ^actualites/([a-zA-Z0-9_-]+)$ /actualites/newsletter.php?slug=$1 [L,QSA]
RewriteRule ^p/([a-z0-9/-]+)/?$ /p/dispatch.php?slug=$1 [L,QSA]

ErrorDocument 404 /404.php

<FilesMatch ".*\.gpx$">
  Header set Content-Disposition attachment
  #Header set Content-Type application/gpx+xml
  ForceType application/gpx+xml
  Header set Cache-Control "max-age=31536000, public, must-revalidate"
</FilesMatch>

<FilesMatch ".*\.geojson$">
  # Force le bon Content-Type pour que la rÃĻgle DEFLATE matche (sinon Apache
  # tombe sur text/plain ou octet-stream selon mime.types).
  ForceType application/geo+json
  Header set Cache-Control "max-age=31536000, public, must-revalidate"
</FilesMatch>

<FilesMatch ".*\.(webp|png|jpg|jpeg)">
  Header set Cache-Control "max-age=31536000, public, must-revalidate"
</FilesMatch>

# Disable caching for JS files â sauf les bundles de build versionnÃĐs
# (cf. plus bas). Le nÃĐgative-lookahead exclut map-{x.y.z}.js et map-maplibre-{x.y.z}.js
# pour qu'ils puissent ÃŠtre cachÃĐs long-terme.
<FilesMatch "^(?!map(?:-maplibre)?-\d[\d.A-Za-z-]*\.js$).+\.js$">
    FileETag None
    Header unset ETag
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# Bundles de build versionnÃĐs (`map-1.9.4.js`, `map-maplibre-5.24.0.js`, etc.).
# Le filename change Ã  chaque upgrade de lib â cache 1 an + immutable. PHP
# rÃĐsout le filename courant via `dist/map-bundles.json` (cf. lib/map-bundle.php).
<FilesMatch "^map(?:-maplibre)?-\d[\d.A-Za-z-]*\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Compression gzip pour les assets bÃĒtis (JS/CSS/JSON/SVG).
# Gain ~70% sur les bundles minifiÃĐs. No-op si mod_deflate n'est pas chargÃĐ.
# Note : Apache sert souvent le JS avec le MIME legacy `application/x-javascript`,
# on inclut donc les deux variantes.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript application/json
  AddOutputFilterByType DEFLATE application/geo+json
  AddOutputFilterByType DEFLATE text/css text/javascript text/plain text/xml text/html
  AddOutputFilterByType DEFLATE image/svg+xml application/xml

</IfModule>

# Workaround pour le bug Apache + mod_deflate : mod_deflate ajoute "-gzip" Ã 
# l'ETag dans la rÃĐponse mais ne strip pas le suffixe du If-None-Match entrant,
# donc le navigateur reÃ§oit toujours 200 mÃŠme quand rien n'a changÃĐ. On strip
# le suffixe cÃītÃĐ requÃŠte pour rÃĐaligner. (DeflateAlterETag NoChange serait plus
# propre mais n'est pas autorisÃĐ dans ce .htaccess sur cette config Apache.)
<IfModule mod_headers.c>
  RequestHeader edit "If-None-Match" '^"(.*)-gzip"$' '"$1"'
</IfModule>

DirectoryIndex index.php
<Limit GET POST>
  Allow from all
</Limit>
